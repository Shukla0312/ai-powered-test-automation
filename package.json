{
  "name": "ai-powered-test-automation",
  "version": "1.0.0",
  "description": "Production-minded AI-powered API validation framework using Node.js, Anthropic, and OpenAI",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "npm run test:mock",
    "test:real": "node tests/ai-validation.test.js",
    "test:mock": "USE_MOCK_AI=true node tests/ai-validation.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:unit:reports": "node scripts/run-node-tests-with-reports.js unit-tests tests/unit reports/unit-test-report",
    "test:integration": "USE_MOCK_AI=true node --test tests/integration/*.test.js",
    "test:integration:reports": "USE_MOCK_AI=true node scripts/run-node-tests-with-reports.js integration-tests tests/integration reports/integration-test-report",
    "test:mock:reports": "node scripts/run-command-with-reports.js mock-tests reports/mock-test-report \"npm run test:mock\"",
    "test:benchmark": "node scripts/run-ai-benchmark.js",
    "validate:governance": "node scripts/validate-scenario-governance.js",
    "orchestrate:local": "node scripts/orchestrate-suites.js pr 2",
    "orchestrate:nightly": "node scripts/orchestrate-suites.js nightly 3",
    "lint": "eslint .",
    "dev": "node tests/ai-validation.test.js"
  },
  "keywords": [
    "ai",
    "automation",
    "testing",
    "sdet",
    "openai",
    "llm"
  ],
  "author": "Rahul Shukla",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "axios": "^1.7.0",
    "dotenv": "^16.4.5",
    "openai": "^4.52.0"
  },
  "devDependencies": {
    "nock": "^14.0.13"
  }
}
